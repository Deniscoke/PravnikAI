# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Get your key at platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# Optional model overrides (defaults shown — used if env var unset).
# Recommended production tier (May 2026) — uncomment to upgrade quality:
#   OPENAI_MODEL_DEFAULT=gpt-5.5
#   OPENAI_MODEL_PREMIUM=gpt-5.5-pro
#   OPENAI_MODEL_QUALITY_GATE=gpt-5.4
# Note: GPT-5.5 requires a funded API usage tier that supports this model (see OpenAI docs / rate limits).
# The app sends max_completion_tokens (not max_tokens) for GPT-5 family models — required by the API.
OPENAI_MODEL_DEFAULT=gpt-5.4
OPENAI_MODEL_PREMIUM=gpt-5.4-pro
OPENAI_MODEL_QUALITY_GATE=gpt-5.4

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from your Supabase project: Settings → API
#
# EU DEPLOYMENT: Create your project in an EU region (e.g., eu-central-1)
# for GDPR data residency compliance.

# Public — safe for browser (PostgREST API + RLS)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Private — server-side ONLY. NEVER expose to browser.
# Used for admin operations (account deletion, audit logging, webhook writes).
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ─── Stripe Billing ──────────────────────────────────────────────────────────
# Get these from dashboard.stripe.com/apikeys
# Use TEST keys (sk_test_...) for development, LIVE keys (sk_live_...) for production.

# Secret key — server-side ONLY. NEVER expose to browser.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Webhook signing secret — from Stripe Dashboard → Webhooks → Signing secret
# Or from `stripe listen` CLI during local development.
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Price IDs for each paid tier — from Stripe Dashboard → Products → Prices
# These differ between test mode and live mode.
#
# Pro tier supports monthly + yearly billing:
STRIPE_PRO_MONTHLY_PRICE_ID=price_your-pro-monthly-price-id
STRIPE_PRO_YEARLY_PRICE_ID=price_your-pro-yearly-price-id
#
# Team tier (monthly only for now):
STRIPE_TEAM_MONTHLY_PRICE_ID=price_your-team-monthly-price-id

# ─── App URL ──────────────────────────────────────────────────────────────────
# Used for Stripe Checkout success/cancel redirects.
# Set to http://localhost:3000 in development, your domain in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Upstash Redis — Distributed Rate Limiting ───────────────────────────────
# Get these from console.upstash.com → your database → REST API
# Create a database in an EU region (eu-west-1 or eu-central-1) for GDPR.
# If not set, rate limiting falls back to allow-all (local dev / CI).
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ─── Sentry Error Monitoring ─────────────────────────────────────────────────
# Get DSN from sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@your-org.ingest.sentry.io/your-project-id
